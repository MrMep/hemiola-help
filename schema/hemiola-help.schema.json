{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrMep/hemiola-help/schema/hemiola-help.schema.json",
  "title": "Hemiola Help File",
  "description": "Schema for Hemiola in-app help content files.",
  "type": "object",
  "required": ["version", "language", "sections"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version number."
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}$",
      "description": "ISO 639-1 language code."
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "title", "icon", "entries"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique section identifier. Must be consistent across all languages."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Localized section title."
        },
        "icon": {
          "type": "string",
          "minLength": 1,
          "description": "Material icon name used in the app UI."
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entry"
          }
        },
        "anchor": {
          "type": "string",
          "minLength": 1,
          "description": "Optional stable slug for deep-linking directly to this section (auto-scroll)."
        }
      }
    },
    "entry": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["para", "item", "subtitle", "note", "table"],
          "description": "Entry rendering type."
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Localized text content."
        },
        "anchor": {
          "type": "string",
          "minLength": 1,
          "description": "Optional stable slug for deep-linking directly to this entry (auto-scroll)."
        }
      }
    }
  }
}
